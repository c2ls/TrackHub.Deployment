# =============================================================================
# TrackHub Frontend-Only Environment Configuration
# =============================================================================
# For split deployment where frontend is on a separate server
# Copy this file to .env and update values before deployment
# =============================================================================

# Your frontend domain
DOMAIN=frontend.your-domain.com

# NOTE: there is deliberately no BACKEND_URL here. nginx.frontend.conf only serves the static
# bundle - it does NOT proxy to the backend - so nothing in this deployment consumes such a
# variable. The browser talks to the backend directly using the REACT_APP_* URLs below, which
# are baked into the bundle at BUILD time. Point every REACT_APP_* endpoint at your backend host.

# =============================================================================
# CERTIFICATE / SSL CONFIGURATION
# =============================================================================
# This deployment DOES terminate SSL: nginx.frontend.conf listens on 443 with
# ssl_certificate /etc/nginx/ssl/fullchain.pem and serves the ACME challenge from
# ./certbot/webroot, so this server needs its own Let's Encrypt certificate.

# Contact email for the Let's Encrypt account. REQUIRED: scripts/generate-certs.sh reads it
# (together with DOMAIN above) from this .env, and aborts if it is empty and no email is
# passed as the 2nd argument. The certificates it issues are the ones scripts/renew-ssl.sh
# renews and nginx serves.
LETSENCRYPT_EMAIL=admin@your-domain.com

# NOTE: no CERTIFICATE_PASSWORD / OpenIddict certificate is needed here - the OpenIddict
# signing certificate is a backend-only concern. generate-certs.sh still emits a
# certificate.pfx; on a frontend-only host it is simply unused.

# =============================================================================
# REACT FRONTEND CONFIGURATION
# =============================================================================

# Default map center coordinates
REACT_APP_DEFAULT_LAT=4.624335
REACT_APP_DEFAULT_LNG=-74.063644

# OAuth Client ID
REACT_APP_CLIENT_ID=web_client

# OAuth Endpoints (pointing to backend server)
REACT_APP_AUTHORIZATION_ENDPOINT=https://api.your-domain.com/Identity/authorize
REACT_APP_TOKEN_ENDPOINT=https://api.your-domain.com/Identity/token
REACT_APP_CALLBACK_ENDPOINT=https://frontend.your-domain.com/authentication/callback
REACT_APP_REVOKE_TOKEN_ENDPOINT=https://api.your-domain.com/Identity/revoke
REACT_APP_LOGOUT_ENDPOINT=https://api.your-domain.com/Identity/logout

# API Endpoints (pointing to backend server)
REACT_APP_MANAGER_ENDPOINT=https://api.your-domain.com/Manager/graphql
REACT_APP_TELEMETRY_ENDPOINT=https://api.your-domain.com/Telemetry/graphql
REACT_APP_ROUTER_ENDPOINT=https://api.your-domain.com/Router/graphql
REACT_APP_SECURITY_ENDPOINT=https://api.your-domain.com/Security/graphql
REACT_APP_GEOFENCING_ENDPOINT=https://api.your-domain.com/Geofence/graphql
REACT_APP_REPORTING_ENDPOINT=https://api.your-domain.com/Reporting/
