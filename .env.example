# =============================================================================
# TrackHub Environment Configuration
# =============================================================================
# Copy this file to .env and update values before deployment
# DO NOT commit the .env file to version control
# =============================================================================

# =============================================================================
# SOURCE REPOSITORIES
# =============================================================================
# Where scripts/clone-repos.sh and deploy.sh pull the service source from.
# Defaults target the public repositories; override for a private deployment.

# GitHub account that owns the repositories
GITHUB_OWNER=shernandezp

# Suffix appended to every repository name (e.g. ".Commercial" for private copies)
GITHUB_REPO_SUFFIX=

# Branch to check out
GITHUB_BRANCH=master

# Credentials — required only for private repositories.
# GITHUB_PASSWORD must be a Personal Access Token: GitHub stopped accepting
# account passwords over HTTPS. Create one at
# https://github.com/settings/tokens with the "repo" scope.
GITHUB_USER=
GITHUB_PASSWORD=

# =============================================================================
# GENERAL SETTINGS
# =============================================================================

# Your domain name (e.g., trackhub.example.com)
DOMAIN=your-domain.com

# Allowed CORS origins (frontend URL)
ALLOWED_CORS_ORIGINS=https://your-domain.com

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection strings
# Format: server=<host>;user id=<user>;password=<password>;database=<dbname>;port=<port>

# Security database connection
DB_CONNECTION_SECURITY="server=your-db-server.com;user id=postgres;password=YOUR_SECURE_PASSWORD;database=TrackHubSecurity;port=5432"

# Manager/Application database connection
DB_CONNECTION_MANAGER="server=your-db-server.com;user id=postgres;password=YOUR_SECURE_PASSWORD;database=TrackHub;port=5432"
# Telemetry uses the same TrackHub database (ideally a dedicated role: r/w on schema telemetry, read-only on the app scoping tables).
DB_CONNECTION_TELEMETRY="server=your-db-server.com;user id=postgres;password=YOUR_SECURE_PASSWORD;database=TrackHub;port=5432"

# Centralized logging database connection
DB_CONNECTION_LOGGING="server=your-db-server.com;user id=postgres;password=YOUR_SECURE_PASSWORD;database=TrackHub;port=5432"

# =============================================================================
# CERTIFICATE / SSL CONFIGURATION
# =============================================================================

# Contact email for the Let's Encrypt account. REQUIRED: scripts/generate-certs.sh reads it
# (together with DOMAIN above) from this .env, and aborts if it is empty and no email is
# passed as the 2nd argument. The certificates it issues are the ones scripts/renew-ssl.sh
# renews and nginx serves.
LETSENCRYPT_EMAIL=admin@your-domain.com

# Password for the OpenIddict certificate (certificate.pfx)
CERTIFICATE_PASSWORD=your-certificate-password

# OpenIddict scopes (must match the scopes seeded in config/clients.json)
OPENIDDICT_SCOPES=mobile_scope,driver_mobile_scope,web_scope,service_scope

# -----------------------------------------------------------------------------
# HOST / NON-DOCKER DEPLOYMENTS ONLY - IGNORED BY DOCKER COMPOSE
# -----------------------------------------------------------------------------
# The two keys below are consumed ONLY by scripts/generate-appsettings.sh (and the
# config/appsettings.template.json it renders) when you generate appsettings.json files for a
# host/IIS deployment. No docker-compose file reads them: the containers always get the
# hardcoded OpenIddict__Path=/app/certificates/certificate.pfx and no thumbprint. Changing
# them has NO effect on `docker compose up`.

# Path to the OpenIddict certificate as seen by the service process.
CERTIFICATE_PATH=/app/certificates/certificate.pfx

# Optional SHA-1 thumbprint of the certificate. Leave empty to load purely from file+password.
CERTIFICATE_THUMBPRINT=

# =============================================================================
# ENCRYPTION
# =============================================================================

# Encryption key for secrets stored in the database (use a GUID format)
ENCRYPTION_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# =============================================================================
# SERVICE URLs (Internal Docker Network)
# =============================================================================

# Authority server URL (how services reach the identity provider)
AUTHORITY_URL=https://your-domain.com/Identity

# GraphQL service endpoints (internal Docker network URLs)
GRAPHQL_IDENTITY_SERVICE=http://security:8080/graphql/
GRAPHQL_SECURITY_SERVICE=http://security:8080/graphql/
GRAPHQL_MANAGER_SERVICE=http://manager:8080/graphql/
GRAPHQL_TELEMETRY_SERVICE=http://telemetry:8080/graphql/
GRAPHQL_ROUTER_SERVICE=http://router:8080/graphql/
GRAPHQL_GEOFENCE_SERVICE=http://geofencing:8080/graphql/

# =============================================================================
# REACT FRONTEND CONFIGURATION
# =============================================================================

# Default map center coordinates (when user denies location permission)
REACT_APP_DEFAULT_LAT=4.624335
REACT_APP_DEFAULT_LNG=-74.063644

# OAuth Client ID
REACT_APP_CLIENT_ID=web_client

# OAuth Endpoints (public URLs)
REACT_APP_AUTHORIZATION_ENDPOINT=https://your-domain.com/Identity/authorize
REACT_APP_TOKEN_ENDPOINT=https://your-domain.com/Identity/token
REACT_APP_CALLBACK_ENDPOINT=https://your-domain.com/authentication/callback
REACT_APP_REVOKE_TOKEN_ENDPOINT=https://your-domain.com/Identity/revoke
REACT_APP_LOGOUT_ENDPOINT=https://your-domain.com/Identity/logout

# API Endpoints (public URLs)
REACT_APP_MANAGER_ENDPOINT=https://your-domain.com/Manager/graphql
REACT_APP_ROUTER_ENDPOINT=https://your-domain.com/Router/graphql
REACT_APP_SECURITY_ENDPOINT=https://your-domain.com/Security/graphql
REACT_APP_GEOFENCING_ENDPOINT=https://your-domain.com/Geofence/graphql
REACT_APP_TELEMETRY_ENDPOINT=https://your-domain.com/Telemetry/graphql
REACT_APP_REPORTING_ENDPOINT=https://your-domain.com/Reporting/

# =============================================================================
# SERVICE (client_credentials) OAuth CLIENTS
# =============================================================================
# These are the service-to-service identities registered in config/clients.json
# (serviceClients). The IDs below MUST match the clientId values there, and each
# secret MUST match the corresponding clientSecret. All use scope service_scope.

# SyncWorker background service (device sync, health checks, position sync)
SYNCWORKER_CLIENT_ID=syncworker_client
SYNCWORKER_CLIENT_SECRET=your-syncworker-client-secret

# Router API (Telemetry/Manager system writers, ReverseGeocode)
ROUTER_CLIENT_ID=router_client
ROUTER_CLIENT_SECRET=your-router-client-secret

# Security API (Manager audit/user forwarding)
SECURITY_CLIENT_ID=security_client
SECURITY_CLIENT_SECRET=your-security-client-secret

# Geofencing API (Manager alert emission + dwell-evaluator job runs, spec 08)
GEOFENCE_CLIENT_ID=geofence_client
GEOFENCE_CLIENT_SECRET=your-geofence-client-secret

# =============================================================================
# DOCUMENT MANAGEMENT STORAGE (Manager)
# =============================================================================
# Provider selects where document bytes are stored. One of:
#   LocalFileSystem (default) - persisted to the manager-documents volume. Needs NOTHING
#                               below except DOCUMENT_STORAGE_LOCAL_ROOT.
#   S3                        - AWS S3 or any S3-compatible service (MinIO).
#   AzureBlob                 - Azure Blob Storage.
#
# IMPORTANT: if you set Provider=S3 or Provider=AzureBlob you MUST also uncomment and fill
# the matching block below. The Manager service validates these AT STARTUP and throws
# (container crash-loops) when the required keys are missing:
#   S3        -> DOCUMENT_S3_BUCKET_NAME is required
#   AzureBlob -> DOCUMENT_AZURE_CONTAINER_NAME and DOCUMENT_AZURE_CONNECTION_STRING are required
DOCUMENT_STORAGE_PROVIDER=LocalFileSystem
DOCUMENT_STORAGE_LOCAL_ROOT=/app/documents
# Byte-retention cleanup horizon in days (default 1825 = 5 years)
DOCUMENT_RETENTION_DAYS=1825

# -----------------------------------------------------------------------------
# S3 storage (only when DOCUMENT_STORAGE_PROVIDER=S3) -> DocumentStorage:S3:*
# -----------------------------------------------------------------------------
# Target bucket. REQUIRED for Provider=S3 (Manager throws at startup without it).
#DOCUMENT_S3_BUCKET_NAME=trackhub-documents
# AWS region system name (e.g. us-east-1). Leave empty when using ServiceUrl (MinIO).
#DOCUMENT_S3_REGION=us-east-1
# Custom endpoint for S3-compatible services (e.g. http://minio:9000). Empty for real AWS S3.
#DOCUMENT_S3_SERVICE_URL=
# Static credentials. Leave BOTH empty to use the default AWS credential chain
# (IAM role / EC2-ECS metadata / AWS_* env vars / shared profile) - recommended on AWS.
#DOCUMENT_S3_ACCESS_KEY=
#DOCUMENT_S3_SECRET_KEY=
# Path-style addressing. Defaults to true when DOCUMENT_S3_SERVICE_URL is set (MinIO needs it),
# false for real AWS S3.
#DOCUMENT_S3_FORCE_PATH_STYLE=false
# Lifetime of the presigned download URLs handed to clients (default 5).
#DOCUMENT_S3_PRESIGNED_EXPIRY_MINUTES=5

# -----------------------------------------------------------------------------
# Azure Blob storage (only when DOCUMENT_STORAGE_PROVIDER=AzureBlob) -> DocumentStorage:AzureBlob:*
# -----------------------------------------------------------------------------
# Blob container. REQUIRED for Provider=AzureBlob (Manager throws at startup without it).
#DOCUMENT_AZURE_CONTAINER_NAME=documents
# Storage account connection string. REQUIRED for Provider=AzureBlob (Manager throws without it).
#DOCUMENT_AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
# Lifetime of the SAS download URLs handed to clients (default 5).
#DOCUMENT_AZURE_SAS_EXPIRY_MINUTES=5

# =============================================================================
# ALERTS & NOTIFICATIONS (spec 05) -> Manager AppSettings:* (see .env.backend.example
# for the full commented reference)
# =============================================================================
#PORTAL_BASE_URL=https://trackhub.example.com
#NOTIFICATION_DELIVERY_RETENTION_DAYS=90
#SMTP_HOST=
#SMTP_PORT=25
#SMTP_USERNAME=
#SMTP_PASSWORD=
#SMTP_USE_STARTTLS=false
#SMTP_FROM_ADDRESS=alerts@trackhub.example.com
#SMTP_FROM_NAME=TrackHub Alerts
#WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0
#WHATSAPP_PHONE_NUMBER_ID=
#WHATSAPP_ACCESS_TOKEN=
#WHATSAPP_TEMPLATE_NAME=trackhub_alert
