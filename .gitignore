# TrackHub Deployment Files
# Ignore sensitive configuration

# Environment files with secrets
.env
!.env.example
!.env.frontend.example
!.env.backend.example

# Let's Encrypt ACME webroot (created by scripts/generate-certs.sh and scripts/renew-ssl.sh,
# bind-mounted into nginx as /var/www/certbot)
certbot/

# Generated appsettings.json files (created by scripts/sync-config.sh / generate-appsettings.sh)
generated/

# Certificates
certificates/*.pem
certificates/*.pfx
certificates/*.key
certificates/*.crt
certificates/*.csr
!certificates/.gitkeep

# OAuth clients configuration with secrets
config/clients.json
!config/clients.json.example

# Backups
backups/

# Docker volumes
volumes/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
