{
  "_comment": "Master configuration template for all TrackHub services",
  "_usage": "Run ./scripts/generate-appsettings.sh to generate service-specific appsettings.json files",
  
  "common": {
    "Serilog": {
      "Using": [
        "Serilog.Sinks.PostgreSQL.Configuration"
      ],
      "MinimumLevel": {
        "Default": "Information",
        "Override": {
          "Microsoft": "Warning",
          "Microsoft.AspNetCore": "Warning",
          "Microsoft.Hosting.Lifetime": "Information",
          "System": "Warning"
        }
      },
      "WriteTo": [
        { "Name": "Console" },
        {
          "Name": "PostgreSQL",
          "Args": {
            "connectionString": "Logging",
            "tableName": "logs",
            "needAutoCreateTable": true,
            "batchSizeLimit": 50,
            "period": "00:00:02"
          }
        }
      ]
    },
    "Columns": {
      "message": "RenderedMessageColumnWriter",
      "message_template": "MessageTemplateColumnWriter",
      "level": {
        "Name": "LevelColumnWriter",
        "Args": {
          "renderAsText": true,
          "dbType": "Varchar"
        }
      },
      "raise_date": "TimestampColumnWriter",
      "exception": "ExceptionColumnWriter",
      "properties": "LogEventSerializedColumnWriter",
      "machine_name": {
        "Name": "SinglePropertyColumnWriter",
        "Args": {
          "propertyName": "MachineName",
          "writeMethod": "Raw"
        }
      },
      "application": {
        "Name": "SinglePropertyColumnWriter",
        "Args": {
          "propertyName": "Application",
          "writeMethod": "Raw"
        }
      },
      "environment_name": {
        "Name": "SinglePropertyColumnWriter",
        "Args": {
          "propertyName": "EnvironmentName",
          "writeMethod": "Raw"
        }
      }
    },
    "AllowedHosts": "*",
    "AllowedCorsOrigins": "${ALLOWED_CORS_ORIGINS}",
    "AuthorityServer": {
      "Authority": "${AUTHORITY_URL}",
      "ValidateAudience": true,
      "ValidAudience": "trackhub_api",
      "ValidateIssuer": true,
      "ValidateIssuerSigningKey": true
    },
    "OpenIddict": {
      "LoadCertFromFile": true,
      "Path": "${CERTIFICATE_PATH}",
      "Password": "${CERTIFICATE_PASSWORD}",
      "Thumbprint": "${CERTIFICATE_THUMBPRINT}"
    }
  },

  "services": {
    "authority": {
      "ConnectionStrings": {
        "Security": "${DB_CONNECTION_SECURITY}",
        "Logging": "${DB_CONNECTION_LOGGING}"
      },
      "OpenIddict": {
        "LoadCertFromFile": true,
        "Path": "${CERTIFICATE_PATH}",
        "Password": "${CERTIFICATE_PASSWORD}",
        "Thumbprint": "${CERTIFICATE_THUMBPRINT}",
        "Scopes": "${OPENIDDICT_SCOPES}"
      }
    },

    "security": {
      "ConnectionStrings": {
        "Security": "${DB_CONNECTION_SECURITY}",
        "Logging": "${DB_CONNECTION_LOGGING}"
      },
      "AuthorityServer": {
        "ClientId": "${SECURITY_CLIENT_ID}",
        "ClientSecret": "${SECURITY_CLIENT_SECRET}",
        "Scope": "service_scope"
      },
      "AppSettings": {
        "GraphQLManagerService": "${GRAPHQL_MANAGER_SERVICE}",
        "EncryptionKey": "${ENCRYPTION_KEY}"
      }
    },

    "manager": {
      "ConnectionStrings": {
        "DefaultConnection": "${DB_CONNECTION_MANAGER}",
        "Logging": "${DB_CONNECTION_LOGGING}"
      },
      "AppSettings": {
        "GraphQLIdentityService": "${GRAPHQL_IDENTITY_SERVICE}",
        "GraphQLSecurityService": "${GRAPHQL_SECURITY_SERVICE}",
        "GraphQLRouterService": "${GRAPHQL_ROUTER_SERVICE}",
        "EncryptionKey": "${ENCRYPTION_KEY}"
      },
      "_DocumentStorage_comment": "Provider = LocalFileSystem (default) | S3 | AzureBlob. LocalFileSystem uses LocalRootPath only. S3 REQUIRES S3.BucketName and AzureBlob REQUIRES AzureBlob.ContainerName + AzureBlob.ConnectionString - the Manager throws at startup when they are missing. Populate them via the DOCUMENT_S3_* / DOCUMENT_AZURE_* variables in .env (see .env.example).",
      "DocumentStorage": {
        "Provider": "${DOCUMENT_STORAGE_PROVIDER}",
        "LocalRootPath": "${DOCUMENT_STORAGE_LOCAL_ROOT}",
        "RetentionDays": "${DOCUMENT_RETENTION_DAYS}",
        "S3": {
          "BucketName": "${DOCUMENT_S3_BUCKET_NAME}",
          "Region": "${DOCUMENT_S3_REGION}",
          "ServiceUrl": "${DOCUMENT_S3_SERVICE_URL}",
          "ForcePathStyle": "${DOCUMENT_S3_FORCE_PATH_STYLE}",
          "AccessKey": "${DOCUMENT_S3_ACCESS_KEY}",
          "SecretKey": "${DOCUMENT_S3_SECRET_KEY}",
          "PresignedExpiryMinutes": "${DOCUMENT_S3_PRESIGNED_EXPIRY_MINUTES}"
        },
        "AzureBlob": {
          "ConnectionString": "${DOCUMENT_AZURE_CONNECTION_STRING}",
          "ContainerName": "${DOCUMENT_AZURE_CONTAINER_NAME}",
          "SasExpiryMinutes": "${DOCUMENT_AZURE_SAS_EXPIRY_MINUTES}"
        }
      }
    },

    "router": {
      "ConnectionStrings": {
        "Logging": "${DB_CONNECTION_LOGGING}"
      },
      "AuthorityServer": {
        "ClientId": "${ROUTER_CLIENT_ID}",
        "ClientSecret": "${ROUTER_CLIENT_SECRET}",
        "Scope": "service_scope"
      },
      "AppSettings": {
        "GraphQLIdentityService": "${GRAPHQL_IDENTITY_SERVICE}",
        "GraphQLManagerService": "${GRAPHQL_MANAGER_SERVICE}",
        "GraphQLGeofenceService": "${GRAPHQL_GEOFENCE_SERVICE}",
        "GraphQLTelemetryService": "${GRAPHQL_TELEMETRY_SERVICE}",
        "EncryptionKey": "${ENCRYPTION_KEY}",
        "Protocols": ["CommandTrack", "Flespi", "GeoTab", "GpsGate", "Navixy", "Samsara", "Traccar", "Wialon"]
      }
    },

    "syncworker": {
      "_comment": "Background worker (device sync, health checks, position sync). client_credentials only - it has no inbound API, hence IsService=true + Scope=service_scope. Protocols MUST stay in sync with the router list above.",
      "ConnectionStrings": {
        "Logging": "${DB_CONNECTION_LOGGING}"
      },
      "AuthorityServer": {
        "ClientId": "${SYNCWORKER_CLIENT_ID}",
        "ClientSecret": "${SYNCWORKER_CLIENT_SECRET}",
        "IsService": true,
        "Scope": "service_scope"
      },
      "AppSettings": {
        "GraphQLIdentityService": "${GRAPHQL_IDENTITY_SERVICE}",
        "GraphQLManagerService": "${GRAPHQL_MANAGER_SERVICE}",
        "GraphQLTelemetryService": "${GRAPHQL_TELEMETRY_SERVICE}",
        "GraphQLGeofenceService": "${GRAPHQL_GEOFENCE_SERVICE}",
        "EncryptionKey": "${ENCRYPTION_KEY}",
        "Protocols": ["CommandTrack", "Flespi", "GeoTab", "GpsGate", "Navixy", "Samsara", "Traccar", "Wialon"]
      }
    },

    "geofencing": {
      "ConnectionStrings": {
        "DefaultConnection": "${DB_CONNECTION_MANAGER}",
        "Logging": "${DB_CONNECTION_LOGGING}"
      },
      "AppSettings": {
        "GraphQLIdentityService": "${GRAPHQL_IDENTITY_SERVICE}"
      }
    },

    "telemetry": {
      "ConnectionStrings": {
        "DefaultConnection": "${DB_CONNECTION_TELEMETRY}",
        "Logging": "${DB_CONNECTION_LOGGING}"
      },
      "AppSettings": {
        "GraphQLIdentityService": "${GRAPHQL_IDENTITY_SERVICE}"
      }
    },

    "reporting": {
      "ConnectionStrings": {
        "Logging": "${DB_CONNECTION_LOGGING}"
      },
      "AppSettings": {
        "GraphQLIdentityService": "${GRAPHQL_IDENTITY_SERVICE}",
        "GraphQLRouterService": "${GRAPHQL_ROUTER_SERVICE}",
        "GraphQLGeofenceService": "${GRAPHQL_GEOFENCE_SERVICE}",
        "GraphQLManagerService": "${GRAPHQL_MANAGER_SERVICE}",
        "GraphQLTelemetryService": "${GRAPHQL_TELEMETRY_SERVICE}"
      }
    }
  }
}
